// --- 3. Run +20 Auto Logic ---
window.updateRunTarget = function(index, teamPrefix) {
    let baseInput = document.getElementById(`${teamPrefix}-run-base-${index}`).value;
    let targetInput = document.getElementById(`${teamPrefix}-run-target-${index}`);
    
    if (baseInput && !isNaN(baseInput)) {
        targetInput.value = parseInt(baseInput) + 20;
    } else {
        targetInput.value = "";
    }
};



