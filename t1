/* Smart Card Design for all screens */
/* Base Card Style (Phone ke liye) */
/* Ye main setting hai jo cards ko bagal-bagal layegi */
.upcoming-grid-container {
    display: grid !important; /* Force grid layout */
    grid-template-columns: 1fr; /* Default: Phone par ek line */
    gap: 20px;
    padding: 10px;
    width: 100%;
}

/* Laptop/Desktop par side-by-side karne ke liye */
@media (min-width: 768px) {
    .upcoming-grid-container {
        grid-template-columns: 1fr 1fr !important; /* Force 2 columns on desktop */
    }
}
.prediction-wrapper {
    max-width: 1000px; /* Upcoming matches ke container ke barabar */
    margin: 20px auto;
    padding: 0 15px;
}
.predict-container {
    display: flex;
    background: white;
    border-radius: 10px;
    overflow: hidden;
    border: 3px solid #111;
}
@media (max-width: 768px) {
    .predict-container { flex-direction: column; } /* Phone par seedha */
}
.predict-box {
    flex: 1;
    padding: 15px;
    text-align: center;
    background: #f8f9fa;
}
.border-center {
    border-left: 3px solid #111;
    border-right: 3px solid #111;
}
.predict-box h4 { margin: 0 0 10px 0; font-size: 1.1rem; color: #111; font-weight: 900;}
.predict-box label { display: block; font-size: 0.9rem; font-weight: bold; color: #333; margin-bottom: 5px; }

/* Side-by-side Input Box Logic */
.run-input-group {
    display: flex;
    justify-content: center;
    margin-bottom: 15px;
}
.run-input-group input {
    width: 45%;
    padding: 8px;
    border: 2px solid #ccc;
    text-align: center;
    font-size: 1rem;
    font-weight: bold;
}
.run-input-group input:first-child { border-radius: 5px 0 0 5px; border-right: none;}
.run-input-group input:last-child { border-radius: 0 5px 5px 0; border-left: 2px solid #111;}

.readonly-box { background: #e9ecef; color: #28a745 !important; cursor: not-allowed; }

.predict-box select { width: 90%; padding: 8px; border: 2px solid #ccc; border-radius: 5px; font-weight: bold; text-align: center;}

.predict-action-box {
    flex: 1;
    background: #111;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 20px;
}
.predict-action-box input { width: 80%; padding: 12px; font-size: 1.1rem; border-radius: 5px; text-align: center; margin: 10px 0; font-weight: bold;}
.predict-action-box button { width: 80%; padding: 12px; background: #28a745; color: white; border: none; border-radius: 5px; font-size: 1.2rem; font-weight: bold; cursor: pointer;}
.predict-action-box button:disabled { background: #555; cursor: not-allowed; }
/* Card ka size desktop par control karne ke liye */
.upcoming-card {
    background: #15304b;
    border-radius: 15px;
    padding: 15px;
    border: 1px solid #222;
    width: 100%; /* Card container ki puri width lega */
}
        :root {
            --bg-main: #0b1c2c; --bg-card: #15304b; --bg-header: #11283d;
            --text-light: #ffffff; --text-muted: #a0b2c6;
            --accent-green: #529626; --accent-blue: #1c75bc;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
        body { background-color: var(--bg-main); color: var(--text-light); }

        /* Header & Common */
        header { display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; background-color: var(--bg-header); position: sticky; top: 0; z-index: 100;}
        .logo-section { display: flex; align-items: center; gap: 10px; }
        .logo-section h2 { color: white; font-style: italic; margin: 0; font-size: 20px;}
        .header-buttons button { padding: 6px 10px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; margin-left: 5px; font-size: 12px;}
        .btn-login { background-color: transparent; border: 1px solid var(--text-muted); color: var(--text-light); }
        .btn-register { background-color: var(--accent-green); color: white; }


        /* Sections */
        .page-section { display: none; padding-bottom: 80px; }
        .page-section.active { display: block; }
        .hero-banner { background: linear-gradient(to right, #0a1f33, #15304b); margin: 10px; padding: 20px; border-radius: 10px; }
        .hero-banner h2 { font-size: 18px; margin-bottom: 5px; }
        .hero-banner button { background-color: var(--accent-green); color: white; border: none; padding: 8px 15px; border-radius: 5px; margin-top:10px; cursor: pointer;}
        
        .section-title { padding: 15px 15px 5px 15px; font-size: 14px; font-weight: bold; text-transform: uppercase; color: var(--text-muted);}
        
        /* Live Card */
        .live-card { background-color: var(--bg-card); margin: 10px 15px; border-radius: 10px; padding: 15px; }
        .live-header { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted); margin-bottom: 10px; }
        .match-teams { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .teams-col { font-weight: bold; font-size: 14px; display: flex; flex-direction: column; gap: 5px;}
        .score-col { text-align: right; font-size: 14px; font-weight: bold; }
        
        /* Modals (Popups) */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 2000; justify-content: center; align-items: center; }
        .modal-content { background-color: var(--bg-header); padding: 20px; border-radius: 10px; width: 90%; max-width: 400px; position: relative; }
        .close-modal { position: absolute; top: 10px; right: 15px; font-size: 20px; cursor: pointer; color: var(--text-muted); }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; font-size: 12px; color: var(--text-muted); margin-bottom: 5px;}
        .form-group input { width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #1a3c5e; background: var(--bg-main); color: white; }
        .submit-btn { width: 100%; background-color: var(--accent-blue); color: white; border: none; padding: 12px; border-radius: 5px; font-weight: bold; cursor: pointer; }

        /* Side Menu */
        .side-menu { position: fixed; top: 0; right: -300px; width: 280px; height: 100%; background-color: var(--bg-header); z-index: 1500; transition: 0.3s; padding: 20px; box-shadow: -5px 0 15px rgba(0,0,0,0.5); }
        .side-menu.open { right: 0; }
        .menu-header { display: flex; align-items: center; gap: 10px; font-size: 18px; font-weight: bold; border-bottom: 1px solid #1a3c5e; padding-bottom: 15px; margin-bottom: 15px; }
        .menu-header img { width: 25px; height: 25px; border-radius: 50%; object-fit: cover; }
        .menu-item { padding: 15px 0; border-bottom: 1px solid #1a3c5e; font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 10px; }
        .menu-item i { color: var(--text-muted); width: 20px; }

        /* Bottom Nav */
        .bottom-nav { position: fixed; bottom: 0; width: 100%; background-color: var(--bg-header); display: flex; justify-content: space-around; padding: 10px 0; border-top: 1px solid #1a3c5e; z-index: 1000;}
        .nav-item { display: flex; flex-direction: column; align-items: center; color: var(--text-muted); font-size: 11px; cursor: pointer; gap: 5px;}
        .nav-item.active { color: white; }
        .nav-item i { font-size: 18px; }
        .nav-item.bet-slip { position: relative; top: -15px; background-color: var(--accent-blue); width: 50px; height: 50px; border-radius: 50%; display: flex; justify-content: center; align-items: center; color: white; border: 4px solid var(--bg-main);}

       
        .admin-float-btn { position: fixed; top: 70px; right: 10px; background: red; color: white; padding: 5px 10px; border-radius: 5px; font-size: 12px; cursor: pointer; z-index: 500;}
    </style>
