async function updateLiveCricketData() {
    const container = document.getElementById('ipl-matches-container');
    if (!container) return;

    // A. TIME WINDOW CHECK (IST: 3:30 PM to 11:30 PM)
    const now = new Date();
    const istTime = new Date(now.getTime() + (now.getTimezoneOffset() + 330) * 60000);
    const hours = istTime.getHours();
    const minutes = istTime.getMinutes();
    const currentTimeInMinutes = (hours * 60) + minutes;

    const startTime = (15 * 60) + 30; // 3:30 PM
    const endTime = (23 * 60) + 30;   // 11:30 PM

    if (currentTimeInMinutes < startTime || currentTimeInMinutes > endTime) {
        container.innerHTML = "<p style='text-align:center; color:var(--text-muted); padding:20px;'>Match Time: 3:30 PM - 11:30 PM. Tab tak purane results niche dekhein.</p>";
        return; 
    }

    // B. REFRESH PROTECTION (5 Minute Caching)
    const lastFetch = localStorage.getItem('lastIPLFetch');
    const savedData = localStorage.getItem('savedIPLData');
    const diff = Date.now() - (lastFetch || 0);

    if (lastFetch && savedData && diff < 300000) { // 5 Minute se pehle call nahi hogi
        console.log("Loading from Cache (Limit Saved!)");
        renderIPLMatches(JSON.parse(savedData));
        return;
    }

    // C. ACTUAL API CALL (Only after 5 mins)
    try {
        console.log("Fetching Fresh IPL Data...");
        const apiUrl = `https://api.cricketdata.org/v1/currentMatches?apikey=${CRICKET_API_KEY}`;
        const response = await fetch(`https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(apiUrl)}`);
        const result = await response.json();

        if (result.status === "success" && result.data) {
            localStorage.setItem('lastIPLFetch', Date.now());
            localStorage.setItem('savedIPLData', JSON.stringify(result.data));
            renderIPLMatches(result.data);
        }
    } catch (error) {
        console.error("Sync Error:", error);
        if(savedData) renderIPLMatches(JSON.parse(savedData)); // Error aaye toh purana data dikhao
    }
}

// Helper Function: Match Card banane ke liye
function renderIPLMatches(data) {
    const container = document.getElementById('ipl-matches-container');
    if (!container) return;

    // Sirf IPL matches ko filter karein
    let iplMatches = data.filter(match => 
        match.name && (match.name.toUpperCase().includes("IPL") || match.name.toUpperCase().includes("INDIAN PREMIER LEAGUE"))
    );

    if (iplMatches.length === 0) {
        container.innerHTML = "<p style='text-align:center; color:var(--text-muted); padding:20px;'>Abhi koi IPL match Live nahi hai.</p>";
        return;
    }

    // Live matches ko sabse upar dikhao
    iplMatches.sort((a, b) => (a.ms === "live" ? -1 : 1));
    container.innerHTML = ""; 

    iplMatches.forEach(match => {
        let s1 = "0/0", s2 = "0/0";
        if (match.score && match.score[0]) s1 = `${match.score[0].r}/${match.score[0].w} (${match.score[0].o})`;
        if (match.score && match.score[1]) s2 = `${match.score[1].r}/${match.score[1].w} (${match.score[1].o})`;

        container.innerHTML += `
            <div class="live-card" style="margin-bottom: 10px; border-left: 4px solid ${match.ms === 'live' ? 'red' : 'var(--accent-green)'};">
                <div class="live-header">
                    <span><i class="fa-solid fa-cricket-bat-ball"></i> ${match.name}</span>
                    <span style="color:${match.ms === 'live' ? 'red' : 'var(--accent-green)'}; font-weight:bold;">
                        ${match.ms === 'live' ? '● LIVE' : 'UPCOMING'}
                    </span>
                </div>
                <div class="match-teams" style="padding: 10px 0;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <span style="font-weight: bold;">🏏 ${match.teams[0]}</span>
                        <span style="font-weight: bold;">${s1}</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-weight: bold;">🏏 ${match.teams[1]}</span>
                        <span style="font-weight: bold;">${s2}</span>
                    </div>
                </div>
            </div>`;
    });
}

